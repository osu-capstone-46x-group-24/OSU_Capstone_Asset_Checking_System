VITE_BASE_URL=/OSU_Capstone_Asset_Checking_System/ # for github pages, replace with '/' for local development
VITE_API_BASE_URL=http://localhost:3000/api # defaults to backend native dev server
VITE_SCANNER_BASE_URL=http://localhost:3003 # defaults to scanner native dev server; set to empty in compose for same-origin proxying
VITE_PUBLIC_LANDING_ONLY=true # set to true to only show the public landing page, false to show all pages. Will default to false if not set.
